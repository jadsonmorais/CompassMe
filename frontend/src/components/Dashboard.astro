---
// Dashboard — interactive island
---
<section id="dashboard-section">
  <div id="dashboard-loading" class="state-msg">Carregando progresso…</div>
  <div id="dashboard-content" class="hidden">

    <div class="multiplier-banner hidden" id="multiplier-banner">
      <span id="multiplier-label"></span>
    </div>

    <div class="progress-card">
      <div class="progress-header">
        <span class="progress-title">Progresso de Hoje</span>
        <span id="progress-date" class="progress-date"></span>
      </div>
      <div class="progress-bar-track" role="progressbar" aria-valuemin="0" aria-valuemax="100" id="progress-bar-wrapper">
        <div class="progress-bar-fill" id="progress-bar-fill"></div>
      </div>
      <div class="progress-stats">
        <span id="progress-pct" class="pct"></span>
        <span id="progress-counts" class="counts"></span>
      </div>
    </div>

    <div class="aura-card" role="region" aria-label="Aura">
      <div class="aura-icon" aria-hidden="true">✦</div>
      <div class="aura-info">
        <span class="aura-label" id="aura-label">Aura Total</span>
        <span id="aura-total" class="aura-value" aria-labelledby="aura-label">0</span>
      </div>
      <div class="aura-delta-wrap" aria-live="polite">
        <span id="aura-today" class="aura-delta"></span>
        <span id="aura-reason" class="aura-reason"></span>
      </div>
    </div>

  </div>
  <div id="dashboard-error" class="state-msg error hidden"></div>
</section>

<script>
  import { getDailyProgress } from "../services/ProgressService.ts";
  import type { DailyProgressResponse } from "../services/ProgressService.ts";

  const loadingEl = document.getElementById("dashboard-loading") as HTMLDivElement;
  const contentEl = document.getElementById("dashboard-content") as HTMLDivElement;
  const errorEl = document.getElementById("dashboard-error") as HTMLDivElement;
  const bannerEl = document.getElementById("multiplier-banner") as HTMLDivElement;
  const bannerLabel = document.getElementById("multiplier-label") as HTMLSpanElement;
  const fillEl = document.getElementById("progress-bar-fill") as HTMLDivElement;
  const wrapperEl = document.getElementById("progress-bar-wrapper") as HTMLDivElement;
  const pctEl = document.getElementById("progress-pct") as HTMLSpanElement;
  const countsEl = document.getElementById("progress-counts") as HTMLSpanElement;
  const dateEl = document.getElementById("progress-date") as HTMLSpanElement;
  const auraTotalEl = document.getElementById("aura-total") as HTMLSpanElement;
  const auraTodayEl = document.getElementById("aura-today") as HTMLSpanElement;
  const auraReasonEl = document.getElementById("aura-reason") as HTMLSpanElement;

  import { localDateStr } from "../services/dateUtils.ts";
  const today = localDateStr();
  const reasonLabels: Record<string, string> = {
    all_completed: "Tudo concluído!",
    partial: "Progresso parcial",
    none: "Nenhuma atividade",
  };

  async function load(): Promise<void> {
    const multiplier = parseFloat(localStorage.getItem("daily_multiplier") ?? "1");
    try {
      const data: DailyProgressResponse = await getDailyProgress(today, multiplier);
      render(data);
    } catch (err) {
      loadingEl.classList.add("hidden");
      errorEl.textContent = `Erro ao carregar progresso: ${(err as Error).message}`;
      errorEl.classList.remove("hidden");
    }
  }

  function render(data: DailyProgressResponse): void {
    loadingEl.classList.add("hidden");
    errorEl.classList.add("hidden");
    contentEl.classList.remove("hidden");

    const pct = data.progressPercentage;
    fillEl.style.width = `${pct}%`;
    fillEl.style.background = pct >= 100 ? "#22c55e" : pct >= 50 ? "var(--color-accent)" : "#f59e0b";
    wrapperEl.setAttribute("aria-valuenow", String(pct));
    pctEl.textContent = `${pct.toFixed(1)}%`;
    countsEl.textContent = `${data.completedCount} / ${data.totalActivities} atividades`;
    dateEl.textContent = new Date(data.date + "T12:00:00").toLocaleDateString("pt-BR", { weekday: "long", day: "numeric", month: "long" });

    auraTotalEl.textContent = String(data.auraTotal);
    const sign = data.auraEarned >= 0 ? "+" : "";
    auraTodayEl.textContent = `${sign}${data.auraEarned} hoje`;
    auraTodayEl.style.color = data.auraEarned > 0 ? "#22c55e" : data.auraEarned < 0 ? "#f87171" : "#94a3b8";
    auraReasonEl.textContent = reasonLabels[data.auraReason] ?? data.auraReason;

    if (data.dailyMultiplier > 1) {
      bannerEl.classList.remove("hidden");
      bannerLabel.textContent = `✦ Multiplicador ativo: ${data.dailyMultiplier}× — ganhos amplificados!`;
    } else {
      bannerEl.classList.add("hidden");
    }
  }

  window.addEventListener("progress:refresh", () => load());
  load();
</script>

<style>
  #dashboard-section { max-width: 720px; margin: 0 auto; padding: 1.5rem 1rem; }
  .state-msg { color: #64748b; padding: 1rem 0; font-size: 0.9375rem; }
  .state-msg.error { color: #f87171; }
  .hidden { display: none !important; }

  .multiplier-banner {
    background: linear-gradient(90deg, #0ea5e9 0%, #6366f1 100%);
    color: #fff;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 1rem;
    text-align: center;
  }

  .progress-card {
    background: var(--color-surface);
    border: 1px solid #334155;
    border-radius: 0.75rem;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1rem;
  }
  .progress-header {
    display: flex; justify-content: space-between; align-items: baseline;
    margin-bottom: 0.875rem;
  }
  .progress-title { font-weight: 600; font-size: 1rem; }
  .progress-date { font-size: 0.8125rem; color: #64748b; }
  .progress-bar-track {
    height: 1rem; background: #1e293b; border-radius: 9999px;
    overflow: hidden; margin-bottom: 0.75rem;
    border: 1px solid #334155;
  }
  .progress-bar-fill {
    height: 100%; border-radius: 9999px;
    transition: width 0.4s ease, background 0.3s;
  }
  .progress-stats { display: flex; justify-content: space-between; align-items: baseline; }
  .pct { font-size: 1.75rem; font-weight: 700; color: var(--color-accent); }
  .counts { font-size: 0.875rem; color: #64748b; }

  .aura-card {
    background: var(--color-surface);
    border: 1px solid #334155;
    border-radius: 0.75rem;
    padding: 1.25rem 1.5rem;
    display: flex; align-items: center; gap: 1rem;
  }
  .aura-icon { font-size: 2rem; color: #f59e0b; }
  .aura-info { display: flex; flex-direction: column; gap: 0.125rem; }
  .aura-label { font-size: 0.8125rem; color: #64748b; }
  .aura-value { font-size: 2rem; font-weight: 700; color: #f59e0b; line-height: 1; }
  .aura-delta-wrap { margin-left: auto; text-align: right; display: flex; flex-direction: column; gap: 0.25rem; }
  .aura-delta { font-weight: 600; font-size: 1rem; }
  .aura-reason { font-size: 0.75rem; color: #64748b; }

  @media (max-width: 480px) {
    .progress-header { flex-direction: column; gap: 0.25rem; }
    .pct { font-size: 1.375rem; }
    .aura-card { flex-wrap: wrap; }
    .aura-delta-wrap { margin-left: 0; text-align: left; width: 100%; }
  }
</style>
