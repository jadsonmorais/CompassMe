---
// LoginForm — interactive island
---
<div id="login-form-wrapper">
  <form id="login-form" novalidate>
    <div class="field">
      <label for="login-email">E-mail</label>
      <input id="login-email" type="email" name="email" autocomplete="email" required />
    </div>
    <div class="field">
      <label for="login-password">Senha</label>
      <input id="login-password" type="password" name="password" autocomplete="current-password" required />
    </div>
    <p id="login-error" class="error" aria-live="polite"></p>
    <button type="submit" id="login-btn">Entrar</button>
    <p class="switch">Não tem conta? <a href="/register">Cadastre-se</a></p>
  </form>
</div>

<script>
  import { login } from "../services/AuthService.ts";
  import { setUser } from "../stores/userStore.ts";

  const form = document.getElementById("login-form") as HTMLFormElement;
  const errorEl = document.getElementById("login-error") as HTMLParagraphElement;
  const btn = document.getElementById("login-btn") as HTMLButtonElement;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    errorEl.textContent = "";
    const data = new FormData(form);
    const email = (data.get("email") as string).trim();
    const password = data.get("password") as string;

    btn.disabled = true;
    btn.textContent = "Entrando…";
    try {
      const user = await login(email, password);
      setUser(user);
      window.location.href = "/activities";
    } catch (err) {
      errorEl.textContent = (err as Error).message;
      btn.disabled = false;
      btn.textContent = "Entrar";
    }
  });
</script>

<style>
  #login-form-wrapper {
    max-width: 400px;
    margin: 4rem auto;
    padding: 2rem;
    background: var(--color-surface);
    border-radius: 0.75rem;
    border: 1px solid #334155;
  }
  .field { display: flex; flex-direction: column; gap: 0.375rem; margin-bottom: 1.25rem; }
  label { font-size: 0.875rem; color: #94a3b8; }
  input {
    padding: 0.625rem 0.875rem;
    background: #0f172a;
    border: 1px solid #334155;
    border-radius: 0.5rem;
    color: var(--color-text);
    font-size: 1rem;
  }
  input:focus { outline: 2px solid var(--color-accent); border-color: transparent; }
  button[type="submit"] {
    width: 100%;
    padding: 0.75rem;
    background: var(--color-accent);
    color: #0f172a;
    font-weight: 700;
    border: none;
    border-radius: 0.5rem;
    cursor: pointer;
    font-size: 1rem;
    margin-top: 0.5rem;
  }
  button:disabled { opacity: 0.6; cursor: not-allowed; }
  .error { color: #f87171; font-size: 0.875rem; margin: 0.5rem 0; min-height: 1.25rem; }
  .switch { margin-top: 1rem; font-size: 0.875rem; color: #94a3b8; text-align: center; }
  .switch a { color: var(--color-accent); }
</style>
